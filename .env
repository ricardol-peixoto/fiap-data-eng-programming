# Spark Configuration
SPARK_APP_NAME=DataPipeline
SPARK_MASTER=spark://spark-master:7077
SPARK_WEB_UI_PORT=8080
SPARK_LOG_LEVEL=INFO

# Spark Master Configuration
SPARK_MASTER_MODE=master
SPARK_MASTER_PORT=7077
SPARK_MASTER_RPC_AUTHENTICATION_ENABLED=no
SPARK_MASTER_RPC_ENCRYPTION_ENABLED=no
SPARK_MASTER_LOCAL_STORAGE_ENCRYPTION_ENABLED=no
SPARK_MASTER_SSL_ENABLED=no

# Spark Worker Configuration
SPARK_WORKER_MODE=worker
SPARK_WORKER_MASTER_URL=spark://spark-master:7077

SPARK_DRIVER_MEMORY=2G
SPARK_EXECUTOR_MEMORY=2G
SPARK_EXECUTOR_CORES=2
SPARK_EXECUTOR_INSTANCES=2